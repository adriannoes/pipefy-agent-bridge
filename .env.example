# --- Cursor SDK (Cursor Cloud Agents / programmatic agent harness) ---
# User API key (Cursor Dashboard → API Keys) or service account key (Team settings → Service accounts).
CURSOR_API_KEY=

# Cloud VM clone source (required for make demo-cloud and cloud probes)
CLOUD_REPO_URL=
CLOUD_STARTING_REF=main

# --- Pipefy (via pipefy-mcp-server / pipefy CLI from pipefy-mcp-server repo) ---
# Service account recommended for unattended demos and CI.
# Provision in Pipefy Admin → Service Accounts; grant access to demo pipes.
PIPEFY_SERVICE_ACCOUNT_CLIENT_ID=
PIPEFY_SERVICE_ACCOUNT_CLIENT_SECRET=

# Sandbox pipe for hands-on scenarios (numeric ID)
DEMO_PIPE_ID=
# Organization ID — used by the org-wide `inventory` scenario (list pipes across the org)
DEMO_ORG_ID=

# Phase name as shown in Pipefy UI (for stale_cards scenario)
DEMO_PHASE_NAME=

# --- Optional write scenario (Scenario D: move_card) — opt-in, sandbox pipe only ---
# Leave DEMO_ALLOW_WRITES=false to keep the default tour read-only.
DEMO_ALLOW_WRITES=false
DEMO_CARD_ID=

# --- NVIDIA NeMo Agent Toolkit + NIM ---
# From https://build.nvidia.com/
NVIDIA_API_KEY=

# Optional: NAT workflow config consumed by `make demo-nat` / `nat run --config_file`
NAT_CONFIG_FILE=configs/pipefy_nat_workflow.yml
# Optional: override NIM model for demo-nat (default: meta/llama-3.1-8b-instruct)
# NIM_MODEL=meta/llama-3.1-70b-instruct

# --- PRD-4 semantic search (embeddings extra: uv sync --extra embeddings) ---
# EMBED_PROVIDER=nim
# EMBED_MODEL=nvidia/nv-embedqa-e5-v5
# EMBED_DIM=
# EMBED_BACKEND=cpu
# EMBED_BATCH_SIZE=32
# CARD_TEXT_LIMIT=100
# Optional on-disk cache for passage embeddings (skips NIM re-embed of cards on hit)
# EMBED_CACHE_DIR=.cache/embeddings
